rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function isAdmin() {
      return isSignedIn() && userEmail() == "sjsubratajana@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function storyDocPath(storyId) {
      return /databases/(default)/documents/stories/$(storyId);
    }

    function canWriteStoryAsset(userId, storyId) {
      return isAdmin() || (
        isOwner(userId) &&
        firestore.exists(storyDocPath(storyId)) &&
        firestore.get(storyDocPath(storyId)).data.authorId == userId &&
        firestore.get(storyDocPath(storyId)).data.status in ["draft", "returned"]
      );
    }

    function isImageUpload() {
      return request.resource != null &&
        request.resource.contentType != null &&
        request.resource.contentType.matches('image/.*');
    }

    function isReasonableImage(maxBytes) {
      return isImageUpload() && request.resource.size <= maxBytes;
    }

    match /site_assets/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isReasonableImage(2 * 1024 * 1024);
      allow delete: if isAdmin();
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if (isOwner(userId) || isAdmin()) && isReasonableImage(5 * 1024 * 1024);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if (isOwner(userId) || isAdmin()) && isReasonableImage(8 * 1024 * 1024);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /stories/{userId}/{storyId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if canWriteStoryAsset(userId, storyId) && isReasonableImage(8 * 1024 * 1024);
      allow delete: if canWriteStoryAsset(userId, storyId);
    }

    match /stories/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isReasonableImage(8 * 1024 * 1024);
      allow delete: if isAdmin();
    }
  }
}
