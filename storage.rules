rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function isAdmin() {
      return isSignedIn() && userEmail() == "sjsubratajana@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isImageUpload() {
      return request.resource != null &&
        request.resource.contentType != null &&
        request.resource.contentType.matches('image/.*');
    }

    match /site_assets/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if (isOwner(userId) || isAdmin()) && isImageUpload();
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if (isOwner(userId) || isAdmin()) && isImageUpload();
    }

    match /stories/{storyId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImageUpload();
    }
  }
}
