[debug] [2026-04-06T11:36:32.862Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/journeyspage-c558b/rulesets {"name":"projects/journeyspage-c558b/rulesets/c4a55ea1-da40-4575-ae78-55f22882eed6","source":{"files":[{"content":"rules_version = '2';\n\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function userEmail() {\n      return isSignedIn() && request.auth.token.email != null\n        ? request.auth.token.email.lower()\n        : \"\";\n    }\n\n    function isAdmin() {\n      return isSignedIn() && userEmail() == \"sjsubratajana@gmail.com\";\n    }\n\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function storyAuthorId(storyId) {\n      return firestore.get(\n        /databases/(default)/documents/stories/$(storyId)\n      ).data.authorId;\n    }\n\n    function canWriteStoryAssets(storyId) {\n      return isAdmin() || (isSignedIn() && storyAuthorId(storyId) == request.auth.uid);\n    }\n\n    match /site_assets/{fileName} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    match /avatars/{userId}/{allPaths=**} {\n      allow read: if true;\n      allow write: if isOwner(userId) || isAdmin();\n    }\n\n    match /users/{userId}/{allPaths=**} {\n      allow read: if true;\n      allow write: if isOwner(userId) || isAdmin();\n    }\n\n    match /stories/{storyId}/{allPaths=**} {\n      allow read: if true;\n      allow write: if canWriteStoryAssets(storyId);\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-04-06T11:36:33.234223Z","metadata":{"services":["firebase.storage"]}}
