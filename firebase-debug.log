[debug] [2026-04-06T11:46:43.630Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/journeyspage-c558b/rulesets {"name":"projects/journeyspage-c558b/rulesets/a1204b18-5b1d-40e3-bb07-f5c33febeae6","source":{"files":[{"content":"rules_version = '2';\n\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function userEmail() {\n      return isSignedIn() && request.auth.token.email != null\n        ? request.auth.token.email.lower()\n        : \"\";\n    }\n\n    function isAdmin() {\n      return isSignedIn() && userEmail() == \"sjsubratajana@gmail.com\";\n    }\n\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function isImageUpload() {\n      return request.resource != null &&\n        request.resource.contentType != null &&\n        request.resource.contentType.matches('image/.*');\n    }\n\n    match /site_assets/{fileName} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    match /avatars/{userId}/{allPaths=**} {\n      allow read: if true;\n      allow write: if (isOwner(userId) || isAdmin()) && isImageUpload();\n    }\n\n    match /users/{userId}/{allPaths=**} {\n      allow read: if true;\n      allow write: if (isOwner(userId) || isAdmin()) && isImageUpload();\n    }\n\n    match /stories/{storyId}/{allPaths=**} {\n      allow read: if true;\n      allow write: if isSignedIn() && isImageUpload();\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-04-06T11:46:44.019679Z","metadata":{"services":["firebase.storage"]}}
