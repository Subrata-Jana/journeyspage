rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function isAdmin() {
      return isSignedIn() && (
        userEmail() == "sjsubratajana@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isEditor() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "editor";
    }

    function isReviewStaff() {
      return isAdmin() || isEditor();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNotChangingAdminRole() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]);
    }

    function storyData(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data;
    }

    function canReadStory(storyId) {
      return storyData(storyId).status == "approved" ||
        (isSignedIn() && storyData(storyId).authorId == request.auth.uid) ||
        isAdmin() ||
        canReviewStory(storyId);
    }

    function canReviewStory(storyId) {
      return isEditor() &&
        storyData(storyId).status == "pending" &&
        storyData(storyId).authorId != request.auth.uid;
    }

    function isEditorReviewUpdate() {
      return isEditor() &&
        resource.data.status == "pending" &&
        resource.data.authorId != request.auth.uid &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status in ["approved", "returned", "rejected"] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "published",
          "feedback",
          "adminNotes",
          "updatedAt",
          "reviewedAt",
          "reviewedBy",
          "reviewedByName"
        ]);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);

      allow update: if isAdmin() || (isOwner(userId) && isNotChangingAdminRole()) || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "trophies",
          "xp",
          "inventory",
          "stats",
          "badges",
          "level",
          "points",
          "trackers",
          "trackersCount",
          "tracking",
          "currentRank",
          "lastLoginDate"
        ])
      );
    }

    match /notifications/{noteId} {
      allow read: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid ||
        resource.data.recipientId == "broadcast" ||
        (resource.data.recipientId == "admin" && isReviewStaff()) ||
        isAdmin()
      );

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.recipientId == request.auth.uid ||
        resource.data.recipientId == "broadcast" ||
        (resource.data.recipientId == "admin" && isAdmin())
      );

      allow delete: if isAdmin() || (
        isSignedIn() && resource.data.recipientId == request.auth.uid
      );
    }

    match /stories/{storyId} {
      allow read: if resource.data.status == "approved" ||
        (isSignedIn() && resource.data.authorId == request.auth.uid) ||
        isAdmin() ||
        (isEditor() && resource.data.status == "pending" && resource.data.authorId != request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.status == "draft";

      allow update: if
        isAdmin() ||
        isEditorReviewUpdate() ||
        (
          isSignedIn() &&
          resource.data.authorId == request.auth.uid &&
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          resource.data.status in ["draft", "returned"] &&
          request.resource.data.status in ["draft", "pending", "returned"]
        ) ||
        (
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "likes",
            "likeCount",
            "views",
            "shares",
            "shareCount",
            "sharedBy",
            "tributeCount",
            "giftCount",
            "trendingScore"
          ])
        );

      allow delete: if isAdmin() || (
        isSignedIn() &&
        resource.data.authorId == request.auth.uid &&
        resource.data.status == "draft"
      );

      match /days/{dayId} {
        allow read: if canReadStory(storyId);
        allow write: if isAdmin() || (
          isSignedIn() && storyData(storyId).authorId == request.auth.uid
        );
      }

      match /comments/{commentId} {
        allow read: if canReadStory(storyId);
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin() || (
          isSignedIn() && resource.data.userId == request.auth.uid
        );
      }
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
