rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function isAdmin() {
      return isSignedIn() && (
        userEmail() == "sjsubratajana@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isEditor() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "editor";
    }

    function isReviewStaff() {
      return isAdmin() || isEditor();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCreatingSafeUserProfile() {
      return !request.resource.data.keys().hasAny(["role"]) ||
        request.resource.data.role == "user";
    }

    function isUpdatingOwnProfile(userId) {
      return isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "email",
          "photoURL",
          "avatarUrl",
          "profilePhoto",
          "avatar",
          "coverURL",
          "bio",
          "location",
          "website",
          "facebook",
          "instagram",
          "twitter",
          "youtube",
          "interests",
          "darkMode",
          "onboarded",
          "updatedAt"
        ]);
    }

    function storyData(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data;
    }

    function canReadStory(storyId) {
      return storyData(storyId).status == "approved" ||
        (isSignedIn() && storyData(storyId).authorId == request.auth.uid) ||
        isAdmin() ||
        canReviewStory(storyId);
    }

    function canReviewStory(storyId) {
      return isEditor() &&
        storyData(storyId).status == "pending" &&
        storyData(storyId).authorId != request.auth.uid;
    }

    function isEditorReviewUpdate() {
      return isEditor() &&
        resource.data.status == "pending" &&
        resource.data.authorId != request.auth.uid &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status in ["approved", "returned", "rejected"] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "published",
          "feedback",
          "adminNotes",
          "updatedAt",
          "reviewedAt",
          "reviewedBy",
          "reviewedByName"
        ]);
    }

    function authorStoryFields() {
      return [
        "title",
        "location",
        "country",
        "state",
        "locationData",
        "month",
        "tripDurationDays",
        "itineraryEntryCount",
        "totalCost",
        "budgetBasis",
        "tripType",
        "difficulty",
        "category",
        "aboutPlace",
        "specialNote",
        "youtubeLink",
        "authorId",
        "authorName",
        "authorPhoto",
        "authorRank",
        "published",
        "status",
        "coverImage",
        "coverImageCaption",
        "gallery",
        "updatedAt",
        "modifiedFlags",
        "feedback",
        "contentConsent",
        "revisionCount"
      ];
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isCreatingSafeUserProfile();

      allow update: if isAdmin() || isUpdatingOwnProfile(userId);
    }

    match /notifications/{noteId} {
      allow read: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid ||
        resource.data.recipientId == "broadcast" ||
        (resource.data.recipientId == "admin" && isReviewStaff()) ||
        isAdmin()
      );

      allow create: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.recipientId != "broadcast" &&
        request.resource.data.keys().hasOnly([
          "recipientId",
          "type",
          "title",
          "message",
          "link",
          "actorId",
          "actorName",
          "entityType",
          "entityId",
          "channel",
          "meta",
          "read",
          "createdAt"
        ]) &&
        request.resource.data.read == false &&
        (
          (
            request.resource.data.recipientId == "admin" &&
            request.resource.data.channel == "review" &&
            request.resource.data.entityType == "story" &&
            storyData(request.resource.data.entityId).authorId == request.auth.uid
          ) ||
          (
            request.resource.data.recipientId != "admin" &&
            request.resource.data.actorId == request.auth.uid
          ) ||
          isReviewStaff()
        )
      );

      allow update: if isSignedIn() && (
        isAdmin() || resource.data.recipientId == request.auth.uid ||
        (resource.data.recipientId == "admin" && isReviewStaff())
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);

      allow delete: if isAdmin() || (
        isSignedIn() && resource.data.recipientId == request.auth.uid
      );
    }

    match /stories/{storyId} {
      allow read: if resource.data.status == "approved" ||
        (isSignedIn() && resource.data.authorId == request.auth.uid) ||
        isAdmin() ||
        (isEditor() && resource.data.status == "pending" && resource.data.authorId != request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.status == "draft" &&
        (!request.resource.data.keys().hasAny(["published"]) || request.resource.data.published == false);

      allow update: if
        isAdmin() ||
        isEditorReviewUpdate() ||
        (
          isSignedIn() &&
          resource.data.authorId == request.auth.uid &&
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          resource.data.status in ["draft", "returned"] &&
          request.resource.data.status in ["draft", "pending", "returned"] &&
          request.resource.data.published == false &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(authorStoryFields())
        );

      allow delete: if isAdmin() || (
        isSignedIn() &&
        resource.data.authorId == request.auth.uid &&
        resource.data.status == "draft"
      );

      match /days/{dayId} {
        allow read: if canReadStory(storyId);
        allow write: if isAdmin() || (
          isSignedIn() &&
          storyData(storyId).authorId == request.auth.uid &&
          storyData(storyId).status in ["draft", "returned"]
        );
      }

      match /comments/{commentId} {
        allow read: if canReadStory(storyId);
        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.keys().hasOnly([
            "text",
            "userId",
            "userName",
            "userPhoto",
            "createdAt"
          ]) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 1000;
        allow delete: if isAdmin() || (
          isSignedIn() && resource.data.userId == request.auth.uid
        );
      }
    }

    match /gamificationActions/{actionId} {
      allow read, write: if false;
    }

    match /storyViewActions/{actionId} {
      allow read, write: if false;
    }

    match /treasureOffers/{offerId} {
      allow read, write: if false;
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
